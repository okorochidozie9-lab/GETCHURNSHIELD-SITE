    const style = document.createElement("style");
    style.id = "cs-styles";
    style.textContent = `
      :root { --cs-accent: ${accent}; }

      #cs-root * { box-sizing: border-box; font-family: inherit; }

      /* ── Video Container ── */
      #video-container {
        position: fixed; z-index: 9990;
        background: #000; border-radius: 10px;
        overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,.45);
        transition: all .3s ease;
      }
      #video-container.vc-hidden  { display: none; }
      #video-container.vc-small   { bottom:16px; right:16px; width:280px; }
      #video-container.vc-full    { bottom:0; right:0; width:100vw; height:100vh; border-radius:0; }
