// ==========================================
// CHURN SHIELD v2 — PROFESSIONAL INJECTION LIBRARY
// Usage: ChurnShield.init(config)
//
// PRESERVED LOGIC NERVES (mandatory):
//   Fix 1 — Instant Kill Switch  : completeSection calls closeVideo() + hideDrawer() together
//   Fix 2 — Alarm Triggers       : vc-close and drawer-close both call restartWatchdog()
//   Fix 3 — Mute Rule            : restartWatchdog checks shield-drawer.active (not isVideoActive)
//   Zone 4 — Navigation Persist  : onhashchange never closes a video currently in flight
// ==========================================

(function (global) {
  "use strict";

  // ==========================================
  // DEFAULT CONFIG SHAPE
  // Clients override by passing their own config to ChurnShield.init(config).
  // ==========================================
  const DEFAULT_CONFIG = {
    // Webhook URLs
    webhooks: {
      friction: "",   // fires on shield trigger / identity capture
      success:  "",   // fires on final onboarding complete
    },

    // Timing (ms)
    timing: {
      taskRescue:       15000,  // Zone 3: idle time before help drawer appears on task pages
      homeProfessor:    5000,   // Zone 2 State A: main guide delay on home page
      homeCoach:        3000,   // Zone 2 State B: pro-tip hotspot delay (all tasks complete)
      proTipReward:     10000,  // post-completion reward delay
      qualifiedView:    5000,   // seconds of playback = QUALIFIED_VIEW event
    },

    // Accent / brand colour shown on the help drawer (CSS custom property)
    accentColor: "#6366f1",

    // Task pages: each key is a URL hash; value is the page config.
    // "home" and "home-professor" and "home-coach" are reserved keys.
    pages: {
      // Example structure — replace with real data in ChurnShield.init(config)
      //
      // "#task-one": {
      //   msg:   "Stuck on Task 1? Here's a quick walkthrough.",
      //   video: "https://example.com/task-one.mp4",
      //   label: "Task_Friction",
      //   title: "Task 1 Walkthrough",
      // },
      "#home-professor": {
        msg:   "Need a hand? Here's a quick guide to get you started.",
        video: "",
        label: "Main_Guide",
        title: "Getting Started Guide",
      },
      "#home-coach": {
        msg:   "Pro-Tip Unlocked — your reward is ready.",
        video: "",
        label: "Pro_Tip_Unlocked",
        title: "Pro-Tip Unlocked",
      },
      // Legacy #home entry for Pro-Tip replay
      "#home": {
        video: "",
        label: "Onboarding_Complete",
        title: "Pro-Tip Unlocked",
      },
    },

    // Hash value treated as the "home" / final page
    homeHash: "#home",

    // Hash values that must all be completed to flip home into Coach mode
    completionGates: [], // e.g. ["#task-one", "#task-two"]

    // Storage namespace (avoids collisions on multi-shield deployments)
    namespace: "churnShield",
  };

  // ==========================================
  // SHADOW INJECTION — HTML structure appended to <body>
  // Clients never need to add markup manually.
  // ==========================================
  function injectHTML(accentColor) {
    if (document.getElementById("cs-root")) return; // already injected

    const root = document.createElement("div");
    root.id = "cs-root";

    root.innerHTML = `
      <!-- Video Container -->
      <div id="video-container" class="vc-hidden">
        <div id="vc-header">
          <span id="vc-title">Guide</span>
          <div id="vc-controls">
            <button id="vc-toggle" aria-label="Toggle size">⤢</button>
            <button id="vc-close"  aria-label="Close video">✕</button>
          </div>
        </div>
        <video id="churn-video" playsinline></video>
      </div>

      <!-- Help Drawer -->
      <div id="shield-drawer" class="drawer-hidden" role="complementary" aria-live="polite">
        <p id="shield-message"></p>
        <div id="shield-actions">
          <button id="drawer-watch">Watch</button>
          <button id="drawer-close" aria-label="Dismiss help">✕</button>
        </div>
      </div>

      <!-- Recent-Videos Tab -->
      <button id="recent-tab" class="hidden" aria-label="Recently watched">
        ▶ <span class="recent-tab-count">0</span>
      </button>

      <!-- Recent-Videos Panel -->
      <div id="recent-panel" class="hidden" aria-label="Recently watched videos">
        <div id="recent-panel-header">
          <span>Recently Watched</span>
          <button id="recent-panel-close">✕</button>
        </div>
        <ul id="recent-list"></ul>
      </div>
    `;

    document.body.appendChild(root);
    applyStyles(accentColor);
  }

  function applyStyles(accent) {
