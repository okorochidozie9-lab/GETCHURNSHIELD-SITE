// ==========================================
// PROTOCOL 1 — DOMAIN DETECTION + AUTO-INIT
// Reads window.location.hostname, looks it up in the BRANDS registry,
// and calls ChurnShield.init() only if a matching entry is found.
// Subdomains are supported: "app.payid.app" matches the "payid.app" key.
// ==========================================
(function () {
  var host    = window.location.hostname;
  var matched = null;

  Object.keys(BRANDS).forEach(function (brandDomain) {
    if (host === brandDomain || host.endsWith("." + brandDomain)) {
      matched = BRANDS[brandDomain];
    }
  });

  if (!matched) {
    console.warn("[ChurnShield] No brand config found for host: " + host + ". Engine not started.");
    return;
  }

  ChurnShield.init(matched);
})();
