  // ==========================================
  // INTERNAL ENGINE
  // ==========================================
  function createEngine(config) {

    // Protocol 2 — Namespace Kill Switch.
    if (BLOCKED_NAMESPACES.indexOf(config.namespace) !== -1) {
      console.warn("[ChurnShield] Namespace blocked: " + config.namespace + ". Engine halted.");
      return null;
    }

    var NS = config.namespace;
    var STORAGE_KEYS = {
      email:     NS + ".userEmail",
      lastLabel: NS + ".lastActiveLabel",
      completed: NS + ".completedSections"
    };

    // State
    var userEmail        = localStorage.getItem(STORAGE_KEYS.email)     || "unknown@user.com";
    var lastActiveLabel  = localStorage.getItem(STORAGE_KEYS.lastLabel) || null;
    var completedSections;
    try {
      completedSections = new Set(JSON.parse(sessionStorage.getItem(STORAGE_KEYS.completed) || "[]"));
    } catch (_) {
      completedSections = new Set();
    }

    var recentlyWatched  = [];
    var watchdogTimer;
    var qualifiedViewTimer;
    var proTipTimer;
    var proTipPending    = false;
    var lastFocusedField = "none";

    function persistCompleted() {
      try {
        sessionStorage.setItem(STORAGE_KEYS.completed, JSON.stringify(Array.from(completedSections)));
      } catch (_) {}
    }

    // Helpers
    function isVideoActive() {
      var c = document.getElementById("video-container");
      return c ? !c.classList.contains("vc-hidden") : false;
    }

    function fieldIdOf(el) {
      if (!el) return null;
      return el.id || el.name || el.getAttribute("placeholder") || (el.tagName ? el.tagName.toLowerCase() : null);
    }

    // Webhooks
    function sendSignal(status, extras) {
      var url = config.webhooks.friction;
      if (!url) return;
      var payload = {
        email:              userEmail,
        event:              status,
        last_focused_field: lastFocusedField || "none",
        timestamp:          new Date().toISOString()
      };
      if (extras) {
        Object.keys(extras).forEach(function (k) { payload[k] = extras[k]; });
      }
      fetch(url, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify(payload)
      }).catch(function (err) { console.warn("[ChurnShield] Signal failed:", err); });
    }

    function sendSuccess(extra) {
      var url = config.webhooks.success;
      if (!url) return;
      var payload = { email: userEmail, event: "onboarding_complete", status: "success" };
      if (extra) {
        Object.keys(extra).forEach(function (k) { payload[k] = extra[k]; });
      }
      fetch(url, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify(payload)
      }).catch(function (err) { console.warn("[ChurnShield] Success webhook failed:", err); });
    }

    // Identity Capture — universal, binds to any [data-shield-identity] input.
    function bindIdentityCapture() {
      document.addEventListener("focusout", function (e) {
        var t = e.target;
        if (!t || !t.hasAttribute("data-shield-identity")) return;
        var v = t.value.trim();
        if (v.indexOf("@") !== -1) {
          userEmail = v;
          try { localStorage.setItem(STORAGE_KEYS.email, userEmail); } catch (_) {}
          sendSignal("Identity_Captured");
        }
      });
    }

    // Leaky-Bucket: tracks last input touched for analytics on every friction event.
    function bindFieldTracker() {
      document.addEventListener("focusin", function (e) {
        var t = e.target;
        if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.tagName === "SELECT")) {
          lastFocusedField = fieldIdOf(t);
        }
      });
    }

    // Shield Drawer
    function showShieldUI(pageHash) {
      var cfg = config.pages[pageHash];
      if (!cfg) return;
      if (completedSections.has(pageHash)) return;

      var drawer = document.getElementById("shield-drawer");
      document.getElementById("shield-message").innerText = cfg.msg || "";
      drawer.dataset.video = cfg.video || "";
      drawer.dataset.label = cfg.label || "";
      drawer.dataset.title = cfg.title || "";

      drawer.classList.remove("drawer-hidden", "gold");
      drawer.classList.add("active");
      document.getElementById("recent-tab").classList.add("hidden");

      lastActiveLabel = cfg.label;
      try { localStorage.setItem(STORAGE_KEYS.lastLabel, lastActiveLabel); } catch (_) {}

      sendSignal(cfg.label, { last_focused_field: lastFocusedField || "(none)" });
    }

    function hideDrawer() {
      var drawer = document.getElementById("shield-drawer");
      drawer.classList.remove("active");
      drawer.classList.add("drawer-hidden");
    }

    // Video Player
    function openVideo(videoUrl, title, label, themeClass) {
      if (!videoUrl) return;
      var container = document.getElementById("video-container");
      var player    = document.getElementById("churn-video");

      document.getElementById("vc-title").textContent = title || "Guide";
      player.src = videoUrl;

      container.classList.remove("vc-hidden", "vc-full", "vc-success");
      container.classList.add("vc-small");
      if (themeClass) container.classList.add(themeClass);

      addToRecentlyWatched({ video: videoUrl, title: title, label: label, themeClass: themeClass });

      // Qualified View: 5s of active playback fires a QUALIFIED_VIEW signal.
      var qualifiedSent = false;
      clearTimeout(qualifiedViewTimer);
      var onPlay = function () {
        qualifiedViewTimer = setTimeout(function () {
          if (!qualifiedSent && !player.paused && player.currentTime >= 5) {
            qualifiedSent = true;
            sendSignal((label || "video") + "_QUALIFIED_VIEW");
          }
        }, config.timing.qualifiedView);
      };
      player.addEventListener("play", onPlay, { once: true });

      var p = player.play();
      if (p && typeof p.catch === "function") p.catch(function () {});
    }

    function closeVideo() {
      var container = document.getElementById("video-container");
      var player    = document.getElementById("churn-video");
      player.pause();
      try { player.currentTime = 0; } catch (_) {}
      container.classList.add("vc-hidden");
      container.classList.remove("vc-small", "vc-full", "vc-success");
    }

    function toggleVideoSize() {
      var container = document.getElementById("video-container");
      if (container.classList.contains("vc-full")) {
        container.classList.replace("vc-full", "vc-small");
      } else {
        container.classList.replace("vc-small", "vc-full");
      }
    }

    // Recently Watched
    function addToRecentlyWatched(entry) {
      if (!entry || !entry.video) return;
      var idx = recentlyWatched.findIndex(function (r) { return r.video === entry.video; });
      if (idx !== -1) recentlyWatched.splice(idx, 1);
      recentlyWatched.unshift(entry);
      if (recentlyWatched.length > 8) recentlyWatched.length = 8;
      refreshRecentList();
      updateRecentTab();
    }

    function showRecentTab() {
      document.getElementById("recent-tab").classList.remove("hidden");
      updateRecentTab();
    }

    function updateRecentTab() {
      var count = document.querySelector("#recent-tab .recent-tab-count");
      if (count) count.textContent = String(recentlyWatched.length);
    }

    function refreshRecentList() {
      var list = document.getElementById("recent-list");
      if (!list) return;
      list.innerHTML = "";
      if (!recentlyWatched.length) {
        var empty = document.createElement("li");
        empty.className   = "recent-empty";
        empty.textContent = "No videos watched yet.";
        list.appendChild(empty);
        return;
      }
      recentlyWatched.forEach(function (r) {
        var li = document.createElement("li");
        li.className = "recent-item";

        var titleEl       = document.createElement("span");
        titleEl.className = "recent-title";
        titleEl.textContent = r.title || "Guide";

        var btn           = document.createElement("button");
        btn.className     = "recent-replay";
        btn.textContent   = "Replay";
        btn.addEventListener("click", function () {
          openVideo(r.video, r.title, r.label, r.themeClass);
          hideRecentPanel();
        });

        li.appendChild(titleEl);
        li.appendChild(btn);
        list.appendChild(li);
      });
    }

    function showRecentPanel() {
      refreshRecentList();
      document.getElementById("recent-panel").classList.remove("hidden");
    }

    function hideRecentPanel() {
      document.getElementById("recent-panel").classList.add("hidden");
    }

    // Kill Switch + Section Completion
    function instantKillPendingTriggers() {
      clearTimeout(watchdogTimer);
      clearTimeout(qualifiedViewTimer);
      // proTipTimer is never killed here — the reward must always fire.
    }

    // Fix 1 — Instant Kill Switch: closeVideo() and hideDrawer() fire together.
    function completeSection(hash) {
      if (!hash || completedSections.has(hash)) return;
      completedSections.add(hash);
      persistCompleted();
      instantKillPendingTriggers();
      closeVideo();
      hideDrawer();
      sendSignal(hash.replace("#", "") + "_SECTION_COMPLETED");

      var allDone = config.completionGates.every(function (g) { return completedSections.has(g); });
      if (allDone && config.completionGates.length > 0) {
        scheduleProTip();
      }
    }

    function scheduleProTip() {
      clearTimeout(proTipTimer);
      proTipTimer = setTimeout(function () {
        if (lastActiveLabel) {
          sendSignal(lastActiveLabel + "_SUCCESS_SAVE");
          lastActiveLabel = null;
          try { localStorage.removeItem(STORAGE_KEYS.lastLabel); } catch (_) {}
        }
        proTipPending = true;
        showProTipHotspot(true);
      }, config.timing.proTipReward);
    }

    function showProTipHotspot(fireSignal) {
      var cfg    = config.pages[config.homeHash] || {};
      var drawer = document.getElementById("shield-drawer");
      document.getElementById("shield-message").innerText = "Pro-Tip Unlocked — your reward is ready.";

      drawer.dataset.video = cfg.video  || "";
      drawer.dataset.label = "Pro_Tip_Unlocked";
      drawer.dataset.title = "Pro-Tip Unlocked";
      drawer.dataset.theme = "vc-success";

      drawer.classList.remove("drawer-hidden");
      drawer.classList.add("active", "gold");
      document.getElementById("recent-tab").classList.add("hidden");

      if (fireSignal) sendSignal("Pro_Tip_Unlocked");
    }

    function dismissProTipHotspot() {
      proTipPending = false;
      var drawer = document.getElementById("shield-drawer");
      drawer.classList.remove("gold");
      delete drawer.dataset.theme;
    }

    // Fix 3 — Mute Rule: guard uses drawer.active check, not isVideoActive().
    function restartWatchdog(currentPoint) {
      if (!config.pages[currentPoint]) return;
      if (currentPoint === config.homeHash) return;
      if (completedSections.has(currentPoint)) return;

      // Abort if the help bar is already on screen.
      if (document.getElementById("shield-drawer").classList.contains("active")) return;

      clearTimeout(watchdogTimer);
      watchdogTimer = setTimeout(function () {
        if ((window.location.hash || config.homeHash) !== currentPoint) return;

        // Double-check at fire time — drawer may have appeared during the wait.
        if (document.getElementById("shield-drawer").classList.contains("active")) return;

        showShieldUI(currentPoint);
      }, config.timing.taskRescue);
    }

    function runWatchdog() {
      var currentPoint = window.location.hash || config.homeHash;
      clearTimeout(watchdogTimer);

      // Zone 4 — Navigation Persistence:
      // If a video is currently in flight, do not hide the drawer or close the player.
      // The video continues uninterrupted across hash navigation.
      var videoInFlight = isVideoActive();
      if (!videoInFlight) {
        hideDrawer();
      }

      // Home routing
      if (currentPoint === config.homeHash) {
        sendSuccess();
        sendSignal("Onboarding_Complete_STOP_SEQUENCE");

        var tasksComplete = config.completionGates.every(function (g) {
          return completedSections.has(g);
        });

        if (!tasksComplete) {
          // State A — Professor: triggers main guide after homeProfessor delay.
          watchdogTimer = setTimeout(function () {
            if ((window.location.hash || config.homeHash) !== config.homeHash) return;
            if (isVideoActive()) return;

            var cfg    = config.pages["#home-professor"] || {};
            var drawer = document.getElementById("shield-drawer");
            document.getElementById("shield-message").innerText = cfg.msg || "";
            drawer.dataset.video = cfg.video || "";
            drawer.dataset.label = cfg.label || "";
            drawer.dataset.title = cfg.title || "";
            delete drawer.dataset.theme;

            drawer.classList.remove("drawer-hidden", "gold");
            drawer.classList.add("active");
            document.getElementById("recent-tab").classList.add("hidden");

            lastActiveLabel = cfg.label;
            try { localStorage.setItem(STORAGE_KEYS.lastLabel, lastActiveLabel); } catch (_) {}
            sendSignal(cfg.label);

          }, config.timing.homeProfessor);

        } else {
          // State B — Coach: triggers gold Pro-Tip hotspot after homeCoach delay.
          watchdogTimer = setTimeout(function () {
            if ((window.location.hash || config.homeHash) !== config.homeHash) return;
            proTipPending = true;
            showProTipHotspot(true);
          }, config.timing.homeCoach);
        }

        if (proTipPending) showProTipHotspot(false);
        return;
      }

      // Task pages — Zone 3: taskRescue idle timer.
      if (config.pages[currentPoint] && !completedSections.has(currentPoint)) {
        if (!videoInFlight) {
          watchdogTimer = setTimeout(function () {
            if ((window.location.hash || config.homeHash) !== currentPoint) return;
            if (isVideoActive()) return;
            showShieldUI(currentPoint);
          }, config.timing.taskRescue);
        }
      }

      if (proTipPending) showProTipHotspot(false);
    }

    // Format-Error Shield: fires the drawer immediately on a provably wrong input.
    // Never auto-plays — user must click Watch.
    function fireFormatErrorShield(hash) {
      if (!config.pages[hash]) return;
      if (completedSections.has(hash)) return;

      var drawer = document.getElementById("shield-drawer");
      var alreadyShowingSame =
        drawer.classList.contains("active") &&
        !drawer.classList.contains("gold") &&
        drawer.dataset.label === (config.pages[hash] || {}).label;
      if (alreadyShowingSame) return;

      instantKillPendingTriggers();
